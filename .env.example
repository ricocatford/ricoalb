# Resend (https://resend.com) — contact form delivery
# Create a key at https://resend.com/api-keys and paste it below.
RESEND_API_KEY=

# Inbox that receives messages submitted through /contact.
CONTACT_TO_EMAIL=

# Optional. Defaults to "onboarding@resend.dev" (works immediately).
# Once you verify a domain on Resend, set this to e.g. "hi@your-domain.com".
CONTACT_FROM_EMAIL=
